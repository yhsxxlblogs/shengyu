# ============================================
# 声愈项目环境配置文件
# 复制此文件为 .env 并填写实际值
# ============================================

# 环境模式
development
NODE_ENV=development

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=shengyu
DB_CONNECTION_LIMIT=10

# ============================================
# Redis配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT配置
# 使用以下命令生成强密钥:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
JWT_SECRET=your_random_secret_key_here_min_64_chars_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 服务器配置
# ============================================
PORT=3000
WS_PORT=3001
HOST=0.0.0.0

# ============================================
# 文件上传配置
# ============================================
UPLOAD_PATH=/www/wwwroot/shengyu/shengyu-backend/uploads
MAX_FILE_SIZE=5242880
MAX_IMAGE_SIZE=2097152
MAX_SOUND_SIZE=10485760

# ============================================
# 安全配置
# ============================================
# 允许的域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://shengyu.supersyh.xyz

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt盐轮数
BCRYPT_ROUNDS=10

# ============================================
# 邮件配置（可选）
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# 其他配置
# ============================================
# 管理员账号（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately
ADMIN_EMAIL=admin@example.com
